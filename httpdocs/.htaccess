# Block access to dotfiles
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve existing static files directly (assets/, favicon, robots.txt …)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Route everything else through the Mezzio front controller
    RewriteRule ^ index.php [QSA,L]
</IfModule>
