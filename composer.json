{
    "name": "lexnova/lexnova",
    "type": "project",
    "description": "LexNova – Legal document management",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": ">=8.4",
        "bjeavons/zxcvbn-php": "^1.4",
        "devium/toml": "^1.0",
        "doctrine/dbal": "^3.7",
        "endroid/qr-code": "^5.0",
        "laminas/laminas-diactoros": "^3.3",
        "laminas/laminas-filter": "^2.35",
        "laminas/laminas-i18n": "^2.28",
        "laminas/laminas-inputfilter": "^2.30",
        "laminas/laminas-validator": "^2.64",
        "mezzio/mezzio": "^3.20",
        "mezzio/mezzio-csrf": "^1.3",
        "mezzio/mezzio-fastroute": "^3.11",
        "mezzio/mezzio-session": "^1.10",
        "mezzio/mezzio-session-ext": "^1.6",
        "mezzio/mezzio-twigrenderer": "^2.14",
        "monolog/monolog": "^3.0",
        "php-di/php-di": "^7.1",
        "psr/clock": "^1.0",
        "psr/simple-cache": "^3.0",
        "spomky-labs/otphp": "^11.4",
        "symfony/cache": "^7.0",
        "symfony/console": "^7.0",
        "twig/twig": "^3.0",
        "web-auth/webauthn-lib": "^5.2"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.75",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "LexNova\\": "src/"
        }
    },
    "bin": ["bin/lexnova"],
    "scripts": {
        "analyse": "phpstan analyse --memory-limit=512M",
        "cs-check": "php-cs-fixer check --diff",
        "cs-fix": "php-cs-fixer fix",
        "qa": ["@analyse", "@cs-check"]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
