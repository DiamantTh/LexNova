#!/usr/bin/env php
<?php

declare(strict_types=1);

$root = dirname(__DIR__);

if (!is_file($root . '/vendor/autoload.php')) {
    fwrite(STDERR, "Run 'composer install' first.\n");
    exit(1);
}

require $root . '/vendor/autoload.php';

date_default_timezone_set('UTC');

use LexNova\Console\UserCreateCommand;
use LexNova\Console\UserListCommand;
use LexNova\Console\UserSetPasswordCommand;
use LexNova\Console\UserTotpResetCommand;
use Symfony\Component\Console\Application;
use Symfony\Component\Console\Output\ConsoleOutput;

$container = \LexNova\Application\ContainerFactory::create();

// ── Vertical colour gradient banner — Corporate Blue palette ─────────────
// Deep navy (#0a1928) → slate steel → accent blue (#3273DC) → light blue
// Uses 256-colour ANSI; degrades silently on basic terminals.
$bannerLines = [
    '  ██╗     ███████╗██╗  ██╗███╗   ██╗ ██████╗ ██╗   ██╗ █████╗ ',
    '  ██║     ██╔════╝╚██╗██╔╝████╗  ██║██╔═══██╗██║   ██║██╔══██╗',
    '  ██║     █████╗   ╚███╔╝ ██╔██╗ ██║██║   ██║██║   ██║███████║',
    '  ██║     ██╔══╝   ██╔██╗ ██║╚██╗██║██║   ██║╚██╗ ██╔╝██╔══██║',
    '  ███████╗███████╗██╔╝ ██╗██║ ╚████║╚██████╔╝ ╚████╔╝ ██║  ██║',
    '  ╚══════╝╚══════╝╚═╝  ╚═╝╚═╝  ╚═══╝ ╚═════╝   ╚═══╝  ╚═╝  ╚═╝',
];
// Corporate Blue: #0a1928 deep navy → #005f87 slate → #005fd7 → #3273DC → #5fafff → #87afff
$gradientCodes = [17, 24, 26, 33, 75, 111];
$output = new ConsoleOutput();
foreach ($bannerLines as $i => $line) {
    $code = $gradientCodes[$i % count($gradientCodes)];
    $output->writeln("\e[38;5;{$code}m{$line}\e[0m");
}
$output->writeln('');

// ── Application ──────────────────────────────────────────────────────────────
$application = new Application('LexNova', '1.0.0');
$application->add($container->get(UserCreateCommand::class));
$application->add($container->get(UserListCommand::class));
$application->add($container->get(UserSetPasswordCommand::class));
$application->add($container->get(UserTotpResetCommand::class));
$application->run(null, $output);
