<!doctype html>
<html lang="{{ locale|default('en') }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if error %}{{ trans('Error', locale) }}{% elseif type == 'privacy' %}{{ trans('Privacy Policy', locale) }}{% else %}{{ trans('Imprint', locale) }}{% endif %} · LexNova</title>
    <style>
        :root { color-scheme: light; }
        /* Screen-reader-only utility (WCAG 2.4.1, 1.3.1) */
        .sr-only {
            position: absolute; width: 1px; height: 1px;
            padding: 0; margin: -1px; overflow: hidden;
            clip: rect(0,0,0,0); white-space: nowrap; border: 0;
        }
        /* Skip navigation (WCAG 2.4.1) */
        .skip-link {
            position: absolute; top: -100%; left: 8px;
            background: #5c4a34; color: #fff; padding: 8px 16px;
            border-radius: 0 0 8px 8px; font-size: 14px;
            z-index: 1000; text-decoration: none;
        }
        .skip-link:focus { top: 0; }
        /* Focus indicator (WCAG 2.4.7) */
        :focus-visible { outline: 3px solid #2563eb; outline-offset: 2px; }
        body { font-family: "Georgia","Times New Roman",serif; margin: 0; background: #f4f1ea; color: #1f1f1f; }
        .wrap { max-width: 900px; margin: 0 auto; padding: 48px 20px 80px; }
        header { margin-bottom: 32px; }
        h1 { font-size: 32px; margin: 0 0 8px; }
        .meta { font-size: 14px; color: #4a4a4a; }
        .card { background: #fff; padding: 28px; border: 1px solid #e0d7c9; border-radius: 12px; box-shadow: 0 12px 30px rgba(39,34,28,.06); }
        .section-title { font-size: 18px; text-transform: uppercase; letter-spacing: .08em; margin: 28px 0 12px; color: #5c4a34; }
        .content { line-height: 1.6; white-space: pre-wrap; }
        .error { background: #fff4f2; border: 1px solid #f3b7a8; color: #7b1c0e; padding: 16px; border-radius: 10px; }
    </style>
</head>
<body>
<a class="skip-link" href="#main-content">{{ trans('Skip to main content', locale) }}</a>
<main id="main-content" class="wrap">
    <header>
        <div class="meta">{{ trans('LexNova Legal Documents', locale) }}</div>
        <h1>{% if type == 'privacy' %}{{ trans('Privacy Policy', locale) }}{% else %}{{ trans('Imprint', locale) }}{% endif %}</h1>
    </header>
    <div class="card">
        {% if error %}
            <div class="error" role="alert">{{ error }}</div>
        {% else %}
            <div class="meta">Entity: {{ entity.name }} · <code>{{ entity.hash }}</code></div>
            <div class="section-title">{{ trans('Contact', locale) }}</div>
            <div class="content">{{ entity.contact_data | obfuscate }}</div>
            <div class="section-title">{{ trans('Document', locale) }}</div>
            <div class="content">{{ doc.content | obfuscate }}</div>
            <div class="meta">{{ trans('Version %s · Updated %s', locale)|format(doc.version, doc.updated_at) }}</div>
        {% endif %}
    </div>
</main>
</body>
</html>
