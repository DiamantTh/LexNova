<div class="card" style="max-width:640px;margin:0 auto 24px;">
    <h2>Systemvoraussetzungen</h2>
    {% if prereq.blocked %}
    <div class="notice error" style="margin-bottom:12px;">
        Mindestens eine Pflichtvoraussetzung ist nicht erfüllt. Die Installation kann erst fortgesetzt werden, wenn alle Pflichtpunkte grün sind.
    </div>
    {% endif %}
    <table style="width:100%;font-size:14px;">
        <thead>
            <tr>
                <th style="text-align:left;padding:4px 8px;">Voraussetzung</th>
                <th style="text-align:left;padding:4px 8px;">Status</th>
                <th style="text-align:left;padding:4px 8px;">Wert</th>
            </tr>
        </thead>
        <tbody>
        {% for check in prereq.checks %}
        <tr style="border-top:1px solid #e0d9d0;">
            <td style="padding:5px 8px;">
                {{ check.label }}
                {% if not check.required %}<span style="color:#888;font-size:12px;"> *</span>{% endif %}
            </td>
            <td style="padding:5px 8px;">
                {% if check.ok %}
                    <span style="color:#2e7d32;font-weight:600;">✓ OK</span>
                {% elseif check.required %}
                    <span style="color:#b71c1c;font-weight:600;">✗ Fehlt</span>
                {% else %}
                    <span style="color:#e65100;font-weight:600;">⚠ Fehlt</span>
                {% endif %}
            </td>
            <td style="padding:5px 8px;font-family:monospace;font-size:13px;color:#555;">
                {{ check.value ?? '' }}
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
    <p style="margin-top:10px;font-size:12px;color:#888;">* Empfohlen, aber nicht zwingend erforderlich.</p>
</div>

<div class="card" style="max-width:640px;margin:0 auto;">
    <h2>Setup</h2>
    {% if not installReady %}
        <p>Install-Passwort wird initialisiert — bitte Seite neu laden.</p>
    {% else %}
    <form method="post" action="/install">
        <div style="margin-bottom:16px;">
            <label for="install_pw">Install-Passwort</label>
            <input type="password" id="install_pw" name="install_pw" required autocomplete="off"
                   {% if prereq.blocked %}disabled title="Bitte zuerst alle Pflichtvoraussetzungen erfüllen."{% endif %}>
        </div>
        <div class="actions">
            <button type="submit" name="action" value="unlock"
                    {% if prereq.blocked %}disabled title="Bitte zuerst alle Pflichtvoraussetzungen erfüllen."{% endif %}>
                Installer entsperren
            </button>
        </div>
        {% if prereq.blocked %}
        <p style="color:#b71c1c;font-size:13px;margin-top:8px;">Installation gesperrt — bitte fehlende Pflichtvoraussetzungen beheben und Seite neu laden.</p>
        {% endif %}
    </form>
    {% endif %}
</div>
