{% extends 'layout.html.twig' %}

{% block title %}Install · LexNova{% endblock %}

{% block extra_styles %}
.mono { font-family: monospace; font-size: 1.1em; background: #f0ece4; padding: 3px 8px; border-radius: 4px; }
.section-sep { border: none; border-top: 1px solid #d9d2c7; margin: 20px 0; }
{% endblock %}

{% block body %}
<header>
    <h1>LexNova Installer</h1>
</header>

{% for msg in errors %}
<div class="notice error">{{ msg }}</div>
{% endfor %}
{% for msg in messages %}
<div class="notice success">{{ msg }}</div>
{% endfor %}

{% if generatedPassword %}
<div class="notice success">
    <strong>Install-Passwort (einmalig angezeigt):</strong><br>
    <span class="mono">{{ generatedPassword }}</span><br>
    <small>Sicher aufbewahren. Es wird nicht erneut angezeigt.</small>
</div>
{% endif %}

{% if step == 'done' %}
    {% include 'install/_step_done.html.twig' %}
{% elseif step == 'configure' %}
    {% include 'install/_step_configure.html.twig' %}
{% else %}
    {% include 'install/_step_unlock.html.twig' %}
{% endif %}
{% endblock %}

