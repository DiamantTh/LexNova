{% extends 'layout.html.twig' %}

{% block title %}Admin · LexNova{% endblock %}

{% block body %}
<header>
    <h1>LexNova Admin</h1>
    <form method="post" action="/admin/logout">
        <input type="hidden" name="__csrf" value="{{ csrf_token }}">
        <button type="submit" class="secondary">{{ trans('Logout') }}</button>
    </form>
</header>

{# ── Flash messages ────────────────────────────────────────────────────── #}
{% for msg in errors %}
<div class="notice error" role="alert">{{ msg }}</div>
{% endfor %}
{% for msg in messages %}
<div class="notice success" role="status">{{ msg }}</div>
{% endfor %}
{% if not twig_cache_enabled %}
<div class="notice warning" role="status">Twig-Template-Cache ist deaktiviert. In <code>configs/config.toml</code> aktivieren: <code>[twig]</code> <code>cache = true</code></div>
{% endif %}

{# ── Create user ────────────────────────────────────────────────────────── #}
<div class="card">
    <h2>{{ trans('Create User') }}</h2>
    <form method="post" action="/admin/users/create">
        <input type="hidden" name="__csrf" value="{{ csrf_token }}">
        <div class="grid">
            <div>
                <label for="new_username">{{ trans('Username') }}</label>
                <input type="text" id="new_username" name="username" autocomplete="off" required>
            </div>
            <div>
                <label for="new_role">{{ trans('Role') }}</label>
                <select id="new_role" name="role">
                    <option value="admin">admin</option>
                </select>
            </div>
            <div>
                <label for="new_password">{{ trans('Password') }}</label>
                <input type="password" id="new_password" name="password" class="pw-field"
                       minlength="{{ pw_min }}" maxlength="{{ pw_max }}" required autocomplete="new-password">
                <p class="hint">{{ trans('pw_hint')|format(pw_min, pw_max) }}</p>
            </div>
            <div>
                <label for="new_password_confirm">{{ trans('Confirm password') }}</label>
                <input type="password" id="new_password_confirm" name="password_confirm" class="pw-field"
                       minlength="{{ pw_min }}" maxlength="{{ pw_max }}" required autocomplete="new-password">
            </div>
        </div>
        <div class="actions">
            <button type="submit">{{ trans('Create User') }}</button>
        </div>
    </form>
</div>

{# ── Users table ────────────────────────────────────────────────────────── #}
<div class="card">
    <h2>{{ trans('Users') }}</h2>
    {% if users is empty %}
        <p>{{ trans('No users yet.') }}</p>
    {% else %}
    <table>
        <thead>
            <tr>
                <th scope="col">ID</th>
                <th scope="col">{{ trans('Username') }}</th>
                <th scope="col">{{ trans('Role') }}</th>
                <th scope="col">{{ trans('TOTP Status') }}</th>
                <th scope="col">{{ trans('Created') }}</th>
                <th scope="col">{{ trans('Actions') }}</th>
            </tr>
        </thead>
        <tbody>
        {% for user in users %}
        <tr>
            <td>{{ user.id }}</td>
            <td>{{ user.username }}</td>
            <td>
                <form method="post" action="/admin/users/{{ user.id }}/update" style="display:inline;">
                    <input type="hidden" name="__csrf" value="{{ csrf_token }}">
                    <select name="role" style="width:auto;"
                            aria-label="{{ trans('Role') }} {{ user.username }}">
                        <option value="admin"{{ user.role == 'admin' ? ' selected' : '' }}>admin</option>
                    </select>
                    <input type="password" name="new_password" class="pw-field"
                           placeholder="{{ trans('New password (optional)') }}"
                           aria-label="{{ trans('New password (optional)') }} {{ user.username }}"
                           minlength="{{ pw_min }}" maxlength="{{ pw_max }}" autocomplete="new-password"
                           style="width:200px;">
                    <button type="submit" class="secondary" style="padding:6px 12px;font-size:13px;"
                            aria-label="{{ trans('Update') }} {{ user.username }}">{{ trans('Update') }}</button>
                </form>
            </td>
            <td>
                {% set keys = totp_keys[user.id] ?? [] %}
                {% if user.totp_key_count > 0 %}
                    <details style="cursor:pointer;">
                        <summary style="color:#2e7d32;font-weight:600;list-style:none;cursor:pointer;">
                            {{ trans('active') }} ({{ user.totp_key_count }})
                        </summary>
                        <table style="margin-top:8px;font-size:12px;width:100%;">
                            <thead>
                                <tr>
                                    <th scope="col" style="text-align:left;padding:2px 6px;">ID</th>
                                    <th scope="col" style="text-align:left;padding:2px 6px;">{{ trans('Key label (e.g. Phone, YubiKey)') }}</th>
                                    <th scope="col" style="text-align:left;padding:2px 6px;">{{ trans('active') }}</th>
                                    <th scope="col" style="padding:2px 6px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for key in keys %}
                            <tr>
                                <td style="padding:2px 6px;">{{ key.id }}</td>
                                <td style="padding:2px 6px;">{{ key.label }}</td>
                                <td style="padding:2px 6px;">
                                    {% if key.is_active %}
                                        <span aria-hidden="true">✓</span><span class="sr-only">{{ trans('active') }}</span>
                                    {% else %}
                                        <span aria-hidden="true">–</span><span class="sr-only">{{ trans('inactive') }}</span>
                                    {% endif %}
                                </td>
                                <td style="padding:2px 6px;">
                                    <form method="post"
                                          action="/admin/users/{{ user.id }}/totp-keys/{{ key.id }}/delete"
                                          style="display:inline;"
                                          onsubmit="return confirm('{{ trans('Delete TOTP key') }} #{{ key.id }} ({{ key.label|e('js') }})?')">
                                        <input type="hidden" name="__csrf" value="{{ csrf_token }}">
                                        <button type="submit"
                                                style="background:#b71c1c;padding:2px 7px;font-size:11px;"
                                                aria-label="{{ trans('Delete') }} TOTP: {{ key.label }}">
                                            {{ trans('Delete') }}
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </details>
                {% else %}
                    <span style="color:#767676;">{{ trans('inactive') }}</span>
                {% endif %}
            </td>
            <td>{{ user.created_at }}</td>
            <td style="white-space:nowrap;">
                {# TOTP reset — any user with TOTP active #}
                {% if user.totp_key_count > 0 %}
                <form method="post" action="/admin/totp/reset/{{ user.id }}" style="display:inline;" onsubmit="return confirm('{{ trans('Disable TOTP for this user?') }}')">
                    <input type="hidden" name="__csrf" value="{{ csrf_token }}">
                    <button type="submit" class="secondary" style="padding:4px 10px;font-size:12px;"
                            aria-label="{{ trans('Disable TOTP') }}: {{ user.username }}">{{ trans('Disable TOTP') }}</button>
                </form>
                {% endif %}
                {# Enroll link — for the current user always (to add more keys) #}
                {% if user.id == current_user_id %}
                <a href="/admin/totp/enroll" style="font-size:13px;">{{ trans('Enroll TOTP') }}</a>
                {% endif %}
                {% if user.id != current_user_id %}
                <form method="post" action="/admin/users/{{ user.id }}/delete" style="display:inline;"
                      onsubmit="return confirm('{{ trans('Delete user permanently?') }}')">
                    <input type="hidden" name="__csrf" value="{{ csrf_token }}">
                    <button type="submit" style="background:#b71c1c;padding:4px 10px;font-size:12px;"
                            aria-label="{{ trans('Delete') }}: {{ user.username }}">{{ trans('Delete') }}</button>
                </form>
                {% endif %}
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>

{# ── Create / Edit entity ────────────────────────────────────────────────── #}
<div class="card">
    {% if editEntity %}
        <h2>{{ trans('Edit Entity') }} #{{ editEntity.id }}</h2>
        <form method="post" action="/admin/entities/{{ editEntity.id }}/edit">
    {% else %}
        <h2>{{ trans('Create Legal Entity') }}</h2>
        <form method="post" action="/admin/entities/create">
    {% endif %}
        <input type="hidden" name="__csrf" value="{{ csrf_token }}">
        <div class="grid">
            <div>
                <label for="entity_name">Name</label>
                <input type="text" id="entity_name" name="name"
                       value="{{ editEntity ? editEntity.name : '' }}" required>
            </div>
            <div>
                <label for="entity_contact">{{ trans('Contact Data') }}</label>
                <textarea id="entity_contact" name="contact_data" style="min-height:80px;" required>{{ editEntity ? editEntity.contact_data : '' }}</textarea>
            </div>
        </div>
        <div class="actions">
            <button type="submit">{{ editEntity ? trans('Update Entity') : trans('Create Entity') }}</button>
            {% if editEntity %}
            <a href="/admin" style="align-self:center;font-size:14px;">{{ trans('Cancel') }}</a>
            {% endif %}
        </div>
    </form>
</div>

{# ── Entities table ─────────────────────────────────────────────────────── #}
<div class="card">
    <h2>{{ trans('Legal Entities') }}</h2>
    {% if entities is empty %}
        <p>{{ trans('No entities yet.') }}</p>
    {% else %}
    <table>
        <thead>
            <tr><th scope="col">ID</th><th scope="col">Hash</th><th scope="col">Name</th><th scope="col">{{ trans('Actions') }}</th></tr>
        </thead>
        <tbody>
        {% for entity in entities %}
        <tr>
            <td>{{ entity.id }}</td>
            <td><code>{{ entity.hash }}</code></td>
            <td>{{ entity.name }}</td>
            <td style="white-space:nowrap;">
                <a href="/admin?entity_id={{ entity.id }}" style="font-size:13px;margin-right:8px;">{{ trans('Edit Entity') }}</a>
                <form method="post" action="/admin/entities/{{ entity.id }}/delete" style="display:inline;"
                      onsubmit="return confirm('{{ trans('Delete entity and all its documents permanently?') }}')">
                    <input type="hidden" name="__csrf" value="{{ csrf_token }}">
                    <button type="submit" style="background:#b71c1c;padding:4px 10px;font-size:12px;"
                            aria-label="{{ trans('Delete') }}: {{ entity.name }}">{{ trans('Delete') }}</button>
                </form>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>

{# ── Create / Edit document ─────────────────────────────────────────────── #}
<div class="card">
    {% if editDoc %}
        <h2>{{ trans('Edit Document') }} #{{ editDoc.id }}</h2>
        <form method="post" action="/admin/documents/{{ editDoc.id }}/edit">
    {% else %}
        <h2>{{ trans('Create Document') }}</h2>
        <form method="post" action="/admin/documents/create">
    {% endif %}
        <input type="hidden" name="__csrf" value="{{ csrf_token }}">
        <div class="grid">
            <div>
                <label for="doc_entity">{{ trans('Entity') }}</label>
                <select id="doc_entity" name="entity_id" required>
                    <option value="">{{ trans('— select —') }}</option>
                    {% for entity in entities %}
                    <option value="{{ entity.id }}"
                        {{ editDoc and editDoc.entity_id == entity.id ? 'selected' : '' }}>
                        {{ entity.name }} ({{ entity.hash|slice(0,8) }}…)
                    </option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label for="doc_type">{{ trans('Type') }}</label>
                <select id="doc_type" name="type" required>
                    <option value="imprint" {{ editDoc and editDoc.type == 'imprint' ? 'selected' : '' }}>{{ trans('Imprint') }}</option>
                    <option value="privacy" {{ editDoc and editDoc.type == 'privacy' ? 'selected' : '' }}>{{ trans('Privacy Policy') }}</option>
                </select>
            </div>
            <div>
                <label for="doc_lang">{{ trans('Language') }}</label>
                <input type="text" id="doc_lang" name="language" maxlength="10" placeholder="e.g. en, de"
                    value="{{ editDoc ? editDoc.language : '' }}" required>
            </div>
            <div>
                <label for="doc_version">Version</label>
                <input type="text" id="doc_version" name="version" maxlength="50" placeholder="e.g. 2024-01-01"
                    value="{{ editDoc ? editDoc.version : '' }}" required>
            </div>
        </div>
        <div style="margin-top:14px;">
            <label for="doc_content">{{ trans('Content') }}</label>
            <textarea id="doc_content" name="content" required>{{ editDoc ? editDoc.content : '' }}</textarea>
        </div>
        <div class="actions">
            <button type="submit">{{ editDoc ? trans('Update Document') : trans('Create Document') }}</button>
            {% if editDoc %}
            <a href="/admin" style="align-self:center;font-size:14px;">{{ trans('Cancel') }}</a>
            {% endif %}
        </div>
    </form>
</div>

{# ── Documents table ────────────────────────────────────────────────────── #}
<div class="card">
    <h2>{{ trans('Documents') }}</h2>
    {% if documents is empty %}
        <p>{{ trans('No documents yet.') }}</p>
    {% else %}
    <table>
        <thead>
            <tr><th scope="col">ID</th><th scope="col">{{ trans('Entity') }}</th><th scope="col">{{ trans('Type') }}</th><th scope="col">{{ trans('Language') }}</th><th scope="col">Version</th><th scope="col">{{ trans('Updated') }}</th><th scope="col"></th></tr>
        </thead>
        <tbody>
        {% for doc in documents %}
        <tr>
            <td>{{ doc.id }}</td>
            <td>{{ doc.entity_name }} <small>({{ doc.entity_hash|slice(0,8) }}…)</small></td>
            <td>{{ doc.type }}</td>
            <td>{{ doc.language }}</td>
            <td>{{ doc.version }}</td>
            <td>{{ doc.updated_at }}</td>
            <td style="white-space:nowrap;">
                <a href="/admin?doc_id={{ doc.id }}" style="margin-right:8px;">{{ trans('Edit Document') }}</a>
                <form method="post" action="/admin/documents/{{ doc.id }}/delete" style="display:inline;"
                      onsubmit="return confirm('{{ trans('Delete document permanently?') }}')">
                    <input type="hidden" name="__csrf" value="{{ csrf_token }}">
                    <button type="submit" style="background:#b71c1c;padding:4px 10px;font-size:12px;"
                            aria-label="{{ trans('Delete') }}: {{ doc.entity_name }} / {{ doc.type }} / {{ doc.language }}">{{ trans('Delete') }}</button>
                </form>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>
{% endblock %}

{% block scripts %}
<script src="/assets/zxcvbn.js"></script>
<script>
(function () {
    'use strict';

    const ASCII_RE = /^[\x20-\x7E]+$/;

    // ── EFF Large Wordlist (lazy-loaded on first passphrase request) ──────────
    let effWords = null;

    async function loadEffWordlist() {
        if (effWords !== null) return effWords;
        const r = await fetch('/assets/eff_wordlist.json');
        effWords = await r.json();   // 7776 words
        return effWords;
    }

    /** Diceware: pick wordCount words from the EFF Large Wordlist via CSPRNG. */
    async function generatePassphrase(wordCount = 6) {
        const words = await loadEffWordlist();
        const buf   = new Uint32Array(wordCount);
        crypto.getRandomValues(buf);
        // Each word drawn from 7776 entries → ~12.9 bits/word
        return Array.from(buf, v => words[v % words.length]).join('-');
    }

    /**
     * Random password generator following the Dropbox/zxcvbn standard.
     *
     * pools: lower(26) + upper(26) + digits(10) + symbols(32) = 94 chars
     * 20 chars → log2(94^20) ≈ 131 bits — always zxcvbn score 4.
     *
     * Algorithm mirrors the PHP RandomPasswordGenerator:
     *  1. Guarantee ≥1 char from each required pool.
     *  2. Fill the rest from the full charset.
     *  3. Cryptographically secure Fisher-Yates shuffle.
     */
    function generateRandom(length = 20) {
        const lower   = 'abcdefghijklmnopqrstuvwxyz';
        const upper   = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
        const digits  = '0123456789';
        const symbols = '!"#$%&\'()*+,-./:;<=>?@[\\]^_`{|}~';
        const charset = lower + upper + digits + symbols;  // 94 chars

        const required = [lower, upper, digits, symbols];

        // Rejection-sampling helper: draw one unbiased index in [0, len)
        function randomIndex(len) {
            const max     = Math.floor(0x100000000 / len) * len;
            const buf     = new Uint32Array(1);
            let   val;
            do { crypto.getRandomValues(buf); val = buf[0]; } while (val >= max);
            return val % len;
        }

        const chars = [];

        // One mandatory char per required pool
        for (const pool of required) {
            chars.push(pool[randomIndex(pool.length)]);
        }

        // Fill remaining positions from full charset
        while (chars.length < length) {
            chars.push(charset[randomIndex(charset.length)]);
        }

        // Fisher-Yates shuffle (CSPRNG)
        for (let i = chars.length - 1; i > 0; i--) {
            const j = randomIndex(i + 1);
            [chars[i], chars[j]] = [chars[j], chars[i]];
        }

        return chars.join('');
    }

    // ── Password strength widget ─────────────────────────────────────────────

    function initPasswordField(input) {
        const wrap = document.createElement('div');
        input.parentNode.insertBefore(wrap, input);
        wrap.appendChild(input);

        const bar  = document.createElement('div');
        bar.className = 'pw-strength-bar';
        const fill = document.createElement('div');
        fill.className = 'pw-strength-fill';
        bar.appendChild(fill);
        wrap.appendChild(bar);

        const fb = document.createElement('div');
        fb.className = 'pw-feedback';
        wrap.appendChild(fb);

        const genRow = document.createElement('div');
        genRow.className = 'pw-gen-row';

        // Random button
        const btnRnd = document.createElement('button');
        btnRnd.type  = 'button';
        btnRnd.textContent = '⚡ Random (131 bit)';
        btnRnd.setAttribute('aria-label', 'Random password (131 bit entropy, CSPRNG, 20 chars)');
        btnRnd.title = 'CSPRNG, 94 printable ASCII chars, 20 chars → ~131 bits';
        btnRnd.addEventListener('click', () => {
            input.value = generateRandom(20);
            input.dispatchEvent(new Event('input'));
        });

        // Passphrase button
        const btnPass = document.createElement('button');
        btnPass.type  = 'button';
        btnPass.textContent = '📖 Diceware (78 bit)';
        btnPass.setAttribute('aria-label', 'Diceware passphrase (78 bit entropy, EFF Large Wordlist, 6 words)');
        btnPass.title = 'EFF Large Wordlist, 6 words → ~77.5 bits';
        btnPass.addEventListener('click', async () => {
            btnPass.disabled = true;
            try {
                input.value = await generatePassphrase(6);
                input.dispatchEvent(new Event('input'));
            } finally {
                btnPass.disabled = false;
            }
        });

        genRow.appendChild(btnRnd);
        genRow.appendChild(btnPass);
        wrap.appendChild(genRow);

        // zxcvbn strength meter
        input.addEventListener('input', () => {
            const val = input.value;
            if (!val) {
                fill.className = 'pw-strength-fill';
                fill.style.cssText = '';
                fb.textContent = '';
                return;
            }

            if (!ASCII_RE.test(val)) {
                fill.className = 'pw-strength-fill pw-score-0';
                fb.textContent = 'Password contains non-printable or non-ASCII characters.';
                return;
            }

            if (typeof zxcvbn !== 'undefined') {
                const r = zxcvbn(val);
                fill.className = 'pw-strength-fill pw-score-' + r.score;
                fb.textContent = [
                    r.feedback.warning,
                    ...(r.feedback.suggestions ?? []),
                ].filter(Boolean).join(' ') || ['Very weak', 'Weak', 'Fair', 'Good', 'Strong'][r.score];
            }
        });
    }

    document.querySelectorAll('input.pw-field').forEach(initPasswordField);
})();
</script>

{# ── Audit-Log ──────────────────────────────────────────────────────────── #}
{% if audit_log is defined and audit_log|length > 0 %}
<details style="margin-top:32px;">
    <summary style="cursor:pointer;font-weight:600;font-size:16px;padding:8px 0;">
        {{ trans('Audit log') }} ({{ audit_log|length }})
    </summary>
    <div class="card" style="margin-top:12px;overflow-x:auto;padding:0;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
            <thead>
                <tr style="background:#f6f4ef;text-align:left;">
                    <th scope="col" style="padding:10px 12px;white-space:nowrap;">{{ trans('When') }}</th>
                    <th scope="col" style="padding:10px 12px;">{{ trans('Actor') }}</th>
                    <th scope="col" style="padding:10px 12px;">{{ trans('Action') }}</th>
                    <th scope="col" style="padding:10px 12px;">{{ trans('Target') }}</th>
                    <th scope="col" style="padding:10px 12px;">{{ trans('Detail') }}</th>
                    <th scope="col" style="padding:10px 12px;">IP</th>
                </tr>
            </thead>
            <tbody>
            {% for entry in audit_log %}
                <tr style="border-top:1px solid #ece8e2;">
                    <td style="padding:8px 12px;white-space:nowrap;color:#6a5b4a;">{{ entry.created_at }}</td>
                    <td style="padding:8px 12px;">{{ entry.actor_name ?? '—' }}</td>
                    <td style="padding:8px 12px;font-family:monospace;">{{ entry.action }}</td>
                    <td style="padding:8px 12px;font-family:monospace;">{{ entry.target ?? '—' }}</td>
                    <td style="padding:8px 12px;color:#555;">{{ entry.detail ?? '' }}</td>
                    <td style="padding:8px 12px;color:#6a5b4a;white-space:nowrap;">{{ entry.ip ?? '' }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</details>
{% endif %}
{% endblock %}

