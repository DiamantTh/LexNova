{% extends 'layout.html.twig' %}

{% block title %}{{ trans('Two-Factor Authentication') }} · LexNova{% endblock %}

{% block body %}
<header>
    <h1>LexNova</h1>
</header>

{% for msg in errors %}
<div class="notice error">{{ msg }}</div>
{% endfor %}

<div class="card" style="max-width:480px;margin:0 auto;">
    <h2>{{ trans('Two-Factor Authentication') }}</h2>
    <p style="color:#4a4a4a;margin-bottom:20px;">
        {{ trans('Enter the 8-digit code from your authenticator app to complete sign-in.') }}
    </p>
    <form method="post" action="/admin/totp/verify" autocomplete="off">
        <input type="hidden" name="__csrf" value="{{ csrf_token }}">
        <div style="margin-bottom:18px;">
            <label for="code">{{ trans('Authentication Code') }}</label>
            <input type="text" id="code" name="code"
                   inputmode="numeric" pattern="[0-9]{8}" maxlength="8"
                   required autofocus autocomplete="one-time-code"
                   style="letter-spacing:.25em;font-size:1.5em;text-align:center;width:100%;">
        </div>
        <div class="actions">
            <button type="submit">{{ trans('Verify') }}</button>
            <a href="/admin/login" style="align-self:center;font-size:14px;">{{ trans('Cancel') }}</a>
        </div>
    </form>
</div>
{% endblock %}
