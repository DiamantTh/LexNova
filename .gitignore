# Runtime data (created at install time by InstallService)
/data/*
!/data/.gitkeep

# Cache and logs (created at runtime by bootstrap)
/cache/*
!/cache/.gitkeep
/logs/*
!/logs/.gitkeep

# Config (generated at install time)
/configs/config.toml
/configs/config.php

# Composer
/vendor/
/composer.lock

# Editor
.vscode/
.php-cs-fixer.cache
